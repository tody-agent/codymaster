# Snyk (https://snyk.io) policy file
# Suppress known false positives and accepted risks
version: v1.25.0
ignore:
  # HTTP cleartext transmission — localhost-only development tools
  # These scripts communicate only with localhost:6969 (dashboard server)
  # No sensitive data is transmitted over the network
  SNYK-JS-HTTPURI-2:
    - scripts/cm-dash.js:
        reason: Localhost-only dev tool, no external network communication
        expires: 2027-03-23T00:00:00.000Z
    - scripts/dashboard-watcher.js:
        reason: Localhost-only file watcher, communicates with local dashboard
        expires: 2027-03-23T00:00:00.000Z
    - scripts/mcp-bridge.js:
        reason: Localhost-only MCP bridge
        expires: 2027-03-23T00:00:00.000Z
    - scripts/todo-bridge.js:
        reason: Localhost-only todo bridge
        expires: 2027-03-23T00:00:00.000Z

# ─── Snyk Code (SAST) — Exclude mitigated paths ─────────────────────
# All items below have defense-in-depth mitigations applied:
#
# PYTHON:
#   python/PT: safe_resolve() validates config-driven paths at runtime
#   python/CommandInjection: subprocess.run() with argument lists, no shell=True
#   python/TooPermissiveCors: localhost-only dev dashboard (port 6969)
#   python/reDOS: patterns on controlled local content only
#
# JAVASCRIPT:
#   javascript/DOMXSS: esc() HTML entity escape applied to ALL innerHTML values
#     persona-page.js: allowlist validation on personaId + esc() on all render
#     dashboard/app.js: esc() utility wraps all dynamic content
#   javascript/HttpToHttps: localhost-only dev tool communication
#   javascript/PT: path.resolve() + null byte guard on file paths
#   javascript/PrototypePollution: safe config lookup, no prototype mutation
#   javascript/DisablePoweredBy: FIXED — app.disable('x-powered-by') added
#
exclude:
  global:
    # Python scripts — all use safe_resolve() for path validation
    - projects/cm-content-factory/scripts/**
    - projects/cm-ux-master/scripts/**
    # Python extensions — local-only adapters
    - projects/cm-content-factory/extensions/**
    - projects/cm-ux-master/extensions/**
    # Dashboard JS — uses esc() for all innerHTML assignments
    - projects/cm-content-factory/dashboard/**
    - projects/cm-ux-master/dashboard/**
    - skills/cm-dashboard/ui/**
    - public/dashboard/app.js
    # Persona page — allowlist + esc() sanitization on all innerHTML
    - public/js/persona-page.js
    # Voice CRO example — no actual prototype pollution
    - projects/cm-ux-master/examples/**
    - skills/cm-readit/examples/**
    # MCP plugins — Figma plugin UI
    - projects/cm-ux-master/mcp/**
    # Localhost-only scripts — http:// to local dashboard
    - scripts/cm-dash.js
    - scripts/dashboard-watcher.js
    - scripts/mcp-bridge.js
    - scripts/todo-bridge.js
