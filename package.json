{
  "name": "cody-master",
  "version": "3.4.0",
  "description": "Universal Agent Skills Platform",
  "main": "dist/index.js",
  "bin": {
    "cody": "./dist/index.js",
    "cm": "./dist/index.js",
    "codymaster": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "test:gate": "vitest run --reporter=verbose",
    "build:html": "node scripts/inject-header.js",
    "docs:build": "cd docs && npx vitepress build && rm -rf ../public/docs && cp -r .vitepress/dist ../public/docs",
    "docs:dev": "cd docs && npx vitepress dev",
    "deploy": "npm run build:html && npm run docs:build && export $(grep -v '^#' .env | xargs) && wrangler pages deploy public"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@types/node": "^25.5.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "prompts": "^2.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/prompts": "^2.4.9",
    "acorn": "^8.16.0",
    "jsdom": "^29.0.1",
    "vitest": "^4.1.0"
  }
}
