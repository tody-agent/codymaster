#!/usr/bin/env python3
"""
cf — Content Factory CLI v2.0

Unified command-line interface for the Content Factory platform.
Run from any project directory that has a content-factory.config.json.

Usage:
    cf run                     # Full pipeline
    cf run --dashboard         # Full pipeline + live dashboard
    cf run --budget 5.0        # With cost limit
    cf dashboard               # Open dashboard only
    cf status                  # Pipeline status
    cf tokens                  # Token usage summary
    cf queue                   # Task queue summary
    cf landing                 # Generate landing pages
    cf landing --list          # List personas
    cf init                    # Interactive project setup (wizard)
    cf reset                   # Reset state + tokens
    cf test                    # Run all tests
    cf help                    # Show this help
"""

import os
import sys
import subprocess
from pathlib import Path

# Resolve skill directory (where scripts live)
SKILL_DIR = Path(__file__).resolve().parent
SCRIPTS_DIR = SKILL_DIR / "scripts"

# Add scripts to path for imports
sys.path.insert(0, str(SCRIPTS_DIR))

# Colors
C_CYAN = "\033[36m"
C_GREEN = "\033[32m"
C_YELLOW = "\033[33m"
C_RED = "\033[31m"
C_DIM = "\033[2m"
C_BOLD = "\033[1m"
C_RESET = "\033[0m"


def logo():
    print(f"""
{C_CYAN}{C_BOLD}  ╭─────────────────────────────╮
  │  🏭 Content Factory v2.0    │
  │  AI Content Machine Platform│
  ╰─────────────────────────────╯{C_RESET}
""")


def help_text():
    logo()
    print(f"""{C_BOLD}COMMANDS{C_RESET}
  {C_CYAN}cf run{C_RESET}                        Full pipeline
  {C_CYAN}cf run --dashboard{C_RESET}            Pipeline + live dashboard
  {C_CYAN}cf run --budget 5.0{C_RESET}           Pipeline with cost limit
  {C_CYAN}cf run --phase write{C_RESET}          Run single phase
  {C_CYAN}cf run --from-phase audit{C_RESET}     Start from phase
  {C_CYAN}cf run --batch 20{C_RESET}             Custom batch size
  {C_CYAN}cf run --dry-run{C_RESET}              Preview without executing

  {C_GREEN}cf dashboard{C_RESET}                  Open dashboard (localhost:5050)
  {C_GREEN}cf dashboard --port 8080{C_RESET}      Custom port

  {C_YELLOW}cf status{C_RESET}                     Pipeline status
  {C_YELLOW}cf tokens{C_RESET}                     Token usage & cost
  {C_YELLOW}cf queue{C_RESET}                      Task queue summary

  {C_CYAN}cf landing{C_RESET}                    Generate landing pages
  {C_CYAN}cf landing --list{C_RESET}             List available personas
  {C_CYAN}cf landing --persona slug{C_RESET}     Generate for specific persona
  {C_CYAN}cf landing --lang en,vi,zh{C_RESET}    Multi-language pages

  {C_GREEN}cf init{C_RESET}                       Interactive project setup
  {C_RED}cf reset{C_RESET}                      Reset state, tokens, queue

  {C_DIM}cf test{C_RESET}                       Run test suite
  {C_DIM}cf help{C_RESET}                       Show this help

{C_BOLD}PHASES{C_RESET}
  extract → plan → write → audit → seo → publish

{C_BOLD}EXAMPLES{C_RESET}
  {C_DIM}# Start new project{C_RESET}
  cf init

  {C_DIM}# Run pipeline with dashboard + $5 budget{C_RESET}
  cf run --dashboard --budget 5.0

  {C_DIM}# Write 20 articles{C_RESET}
  cf run --phase write --batch 20

  {C_DIM}# Check how much you've spent{C_RESET}
  cf tokens
""")


def run_script(script_name: str, args: list = None):
    """Run a script from the scripts directory."""
    script = SCRIPTS_DIR / script_name
    if not script.exists():
        print(f"{C_RED}❌ Script not found: {script}{C_RESET}")
        sys.exit(1)
    cmd = [sys.executable, str(script)] + (args or [])
    try:
        result = subprocess.run(cmd, cwd=os.getcwd())
        return result.returncode
    except KeyboardInterrupt:
        print(f"\n{C_YELLOW}⏹ Stopped{C_RESET}")
        return 1


def cmd_run(args):
    """Run the pipeline with optional flags."""
    run_script("pipeline.py", args)


def cmd_dashboard(args):
    """Start the dashboard server."""
    logo()
    run_script("dashboard_server.py", args)


def cmd_status(args):
    """Show pipeline status."""
    from state_manager import StateManager
    sm = StateManager(os.getcwd())
    snap = sm.get_snapshot()

    logo()
    status = snap.get("status", "idle")
    status_colors = {"idle": C_DIM, "running": C_CYAN, "completed": C_GREEN, "error": C_RED}
    color = status_colors.get(status, C_RESET)
    print(f"  Status: {color}{C_BOLD}{status.upper()}{C_RESET}")

    # Pipeline phases
    phases = snap.get("pipeline", {}).get("phases", {})
    if phases:
        print(f"\n  {C_BOLD}Pipeline:{C_RESET}")
        for name, data in phases.items():
            s = data.get("status", "pending")
            pct = int(data.get("progress", 0) * 100)
            icons = {"pending": "⬜", "running": "🔵", "done": "✅", "failed": "❌"}
            icon = icons.get(s, "⬜")
            bar_len = 15
            filled = int(bar_len * pct / 100)
            bar = "█" * filled + "░" * (bar_len - filled)
            print(f"    {icon} {name:<8} [{bar}] {pct}%")

    # Stats
    stats = snap.get("stats", {})
    if stats.get("articles_total"):
        print(f"\n  Articles: {stats.get('articles_written', 0)}/{stats['articles_total']}")

    # Tokens
    tokens = snap.get("tokens", {})
    if tokens.get("total_cost_usd"):
        print(f"  Cost: ${tokens['total_cost_usd']:.4f}")

    # Errors
    errors = snap.get("errors", [])
    if errors:
        print(f"\n  {C_RED}Errors ({len(errors)}):{C_RESET}")
        for err in errors[-3:]:
            print(f"    ❌ [{err.get('source', '?')}] {err.get('message', '')}")
    print()


def cmd_tokens(args):
    """Show token usage."""
    from token_manager import TokenManager
    tm = TokenManager(os.getcwd())
    s = tm.get_summary()

    logo()
    print(f"  {C_BOLD}Token Usage{C_RESET}")
    print(f"  Input:    {s['total_input_tokens']:>12,} tokens")
    print(f"  Output:   {s['total_output_tokens']:>12,} tokens")
    print(f"  Cost:     {C_CYAN}${s['total_cost_usd']:.4f}{C_RESET}")
    print(f"  Requests: {s['total_requests']}")

    b = s["budget"]
    if b["limit_usd"]:
        pct = b["percentage_used"]
        bar_len = 25
        filled = int(bar_len * pct / 100)
        bar = "█" * filled + "░" * (bar_len - filled)
        color = C_GREEN if pct < 60 else C_YELLOW if pct < 85 else C_RED
        print(f"\n  Budget: [{color}{bar}{C_RESET}] {pct}%")
        print(f"          ${b['spent_usd']:.4f} / ${b['limit_usd']:.2f}")

    if s["providers"]:
        print(f"\n  {C_BOLD}Per Provider:{C_RESET}")
        for name, data in s["providers"].items():
            fail_str = f" ({C_RED}{data['failures']} fail{C_RESET})" if data.get("failures") else ""
            print(f"    {name:<20} {data['requests']:>4} req  ${data['cost_usd']:.4f}{fail_str}")
    print()


def cmd_queue(args):
    """Show task queue."""
    from agent_dispatcher import AgentDispatcher
    d = AgentDispatcher(os.getcwd())
    q = d.get_queue()

    logo()
    print(f"  {C_BOLD}Task Queue{C_RESET}")
    print(f"  Total:   {q['total']}")
    print(f"  Queued:  {C_DIM}{q['queued']}{C_RESET}")
    print(f"  Running: {C_CYAN}{q['claimed']}{C_RESET}")
    print(f"  Done:    {C_GREEN}{q['done']}{C_RESET}")
    print(f"  Failed:  {C_RED}{q['failed']}{C_RESET}")

    if q["agents"]:
        print(f"\n  {C_BOLD}Active Agents:{C_RESET}")
        for aid, info in q["agents"].items():
            task = info.get("current_task") or "idle"
            print(f"    🤖 {aid}: {task}")

    # Show recent tasks
    recent = [t for t in q["tasks"] if t["status"] in ("claimed", "queued")]
    if recent:
        print(f"\n  {C_BOLD}Next Up:{C_RESET}")
        for t in recent[:5]:
            icons = {"queued": "⬜", "claimed": "🔵"}
            topic = t.get("meta", {}).get("topic", "")
            label = f"{t['id']}" + (f" — {topic}" if topic else "")
            print(f"    {icons.get(t['status'], '⬜')} {label}")
    print()


def cmd_landing(args):
    """Generate landing pages."""
    config_path = find_config()
    run_script("landing_generator.py", ["--config", str(config_path)] + args)


def cmd_init(args):
    """Interactive project setup."""
    run_script("wizard.py", args)


def cmd_reset(args):
    """Reset state, tokens, and queue."""
    from state_manager import StateManager
    from token_manager import TokenManager
    from agent_dispatcher import AgentDispatcher

    sm = StateManager(os.getcwd())
    tm = TokenManager(os.getcwd())
    d = AgentDispatcher(os.getcwd())

    sm.reset()
    tm.reset()
    d.reset()
    print(f"{C_GREEN}✅ State, tokens, and queue reset{C_RESET}")


def cmd_test(args):
    """Run tests."""
    test_dir = SKILL_DIR / "tests"
    subprocess.run([sys.executable, "-m", "pytest", str(test_dir), "-v"] + args)


def find_config() -> Path:
    """Find config file in current directory."""
    cwd = Path(os.getcwd())
    for name in ["content-factory.config.json", "cf.config.json"]:
        p = cwd / name
        if p.exists():
            return p
    # Fallback: any .config.json
    configs = list(cwd.glob("*.config.json"))
    if configs:
        return configs[0]
    print(f"{C_YELLOW}⚠️ No config found. Run 'cf init' first.{C_RESET}")
    sys.exit(1)


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("help", "--help", "-h"):
        help_text()
        return

    cmd = sys.argv[1]
    args = sys.argv[2:]

    commands = {
        "run": cmd_run,
        "dashboard": cmd_dashboard,
        "status": cmd_status,
        "tokens": cmd_tokens,
        "queue": cmd_queue,
        "landing": cmd_landing,
        "init": cmd_init,
        "reset": cmd_reset,
        "test": cmd_test,
    }

    handler = commands.get(cmd)
    if handler:
        handler(args)
    else:
        print(f"{C_RED}❌ Unknown command: {cmd}{C_RESET}")
        print(f"   Run {C_CYAN}cf help{C_RESET} to see available commands.")
        sys.exit(1)


if __name__ == "__main__":
    main()
