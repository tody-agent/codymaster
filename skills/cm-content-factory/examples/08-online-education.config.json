{
    "niche": "online-education",
    "brand": {
        "name": "SkillForge Academy",
        "slogan": "Learn Skills That Pay",
        "tone": "inspiring-structured",
        "language": "en",
        "colors": {
            "primary": "#4338CA",
            "secondary": "#818CF8",
            "accent": "#EEF2FF"
        }
    },
    "content": {
        "article_types": [
            {
                "id": "course-review",
                "title_template": "Best {topic_name} Courses 2025: Honest Reviews & Comparison",
                "category": "reviews",
                "seo_intent": "commercial",
                "tags_base": [
                    "course review",
                    "online learning",
                    "best"
                ]
            },
            {
                "id": "career-guide",
                "title_template": "{topic_name} Career Guide: Skills, Salary & How to Get Started",
                "category": "careers",
                "seo_intent": "informational",
                "tags_base": [
                    "career",
                    "salary",
                    "skills"
                ]
            },
            {
                "id": "learning-path",
                "title_template": "{topic_name} Learning Path: From Beginner to Professional in 6 Months",
                "category": "paths",
                "seo_intent": "informational",
                "tags_base": [
                    "learning path",
                    "roadmap",
                    "beginner"
                ]
            },
            {
                "id": "certification-guide",
                "title_template": "{topic_name} Certifications: Which Are Worth It & How to Prepare",
                "category": "certifications",
                "seo_intent": "commercial",
                "tags_base": [
                    "certification",
                    "exam",
                    "prep"
                ]
            },
            {
                "id": "tools-roundup",
                "title_template": "Essential {topic_name} Tools: Free Resources & Premium Picks",
                "category": "tools",
                "seo_intent": "commercial",
                "tags_base": [
                    "tools",
                    "resources",
                    "free"
                ]
            }
        ],
        "frontmatter_schema": {
            "required": [
                "title",
                "slug",
                "description",
                "category"
            ],
            "optional": [
                "date",
                "author",
                "tags",
                "image",
                "difficulty",
                "estimatedTime"
            ]
        },
        "word_count": {
            "min": 1500,
            "max": 3500
        },
        "language": "en"
    },
    "sources": {
        "type": "manual",
        "path": "knowledge/"
    },
    "output": {
        "content_dir": "content/blog/",
        "knowledge_dir": "knowledge/",
        "queue_dir": "topics-queue/"
    },
    "pipeline": {
        "concurrency": 3,
        "ai_provider": "gemini-cli",
        "auto_validate": true,
        "auto_publish": false,
        "git_branch": "main"
    },
    "audit": {
        "error_patterns": [
            "I cannot",
            "Please provide",
            "As an AI"
        ],
        "min_headings": 4,
        "require_faq": true,
        "require_cta": true,
        "require_disclaimer": false
    },
    "memory": {
        "enabled": true,
        "memory_dir": "memory/",
        "auto_learn": true,
        "max_episodic_days": 90
    },
    "research": {
        "auto_research": true,
        "search_provider": "browser",
        "competitor_urls": [],
        "max_sources_per_topic": 10
    },
    "scoring": {
        "reward_praise": 10,
        "reward_engagement": 5,
        "reward_first_pass": 3,
        "penalty_edit": -5,
        "penalty_delete": -10,
        "penalty_audit_fail": -3
    },
    "extensions": {
        "openclaw": {
            "enabled": false
        },
        "hooks": {}
    }
}