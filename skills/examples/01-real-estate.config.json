{
    "niche": "real-estate",
    "brand": {
        "name": "HomeVision Pro",
        "slogan": "Your Dream Home Starts Here",
        "tone": "professional-trustworthy",
        "language": "en",
        "colors": {
            "primary": "#1B365D",
            "secondary": "#C5A55A",
            "accent": "#F5F5F0"
        }
    },
    "content": {
        "article_types": [
            {
                "id": "market-analysis",
                "title_template": "{topic_name} Real Estate Market: Trends, Prices & 2025 Forecast",
                "category": "market",
                "seo_intent": "informational",
                "tags_base": [
                    "market analysis",
                    "home prices",
                    "trends"
                ]
            },
            {
                "id": "buying-guide",
                "title_template": "How to Buy {topic_name}: Complete Step-by-Step Guide",
                "category": "guides",
                "seo_intent": "transactional",
                "tags_base": [
                    "buying guide",
                    "first-time buyer",
                    "tips"
                ]
            },
            {
                "id": "investment-article",
                "title_template": "{topic_name} Investment: ROI, Risks & Expert Analysis",
                "category": "investment",
                "seo_intent": "commercial",
                "tags_base": [
                    "real estate investing",
                    "ROI",
                    "passive income"
                ]
            },
            {
                "id": "neighborhood-guide",
                "title_template": "{topic_name}: Best Neighborhoods, Schools & Lifestyle Guide",
                "category": "neighborhoods",
                "seo_intent": "informational",
                "tags_base": [
                    "neighborhood",
                    "living",
                    "community"
                ]
            },
            {
                "id": "faq-article",
                "title_template": "{topic_name}: Top Questions Home Buyers Ask",
                "category": "faq",
                "seo_intent": "informational",
                "tags_base": [
                    "FAQ",
                    "home buying",
                    "answers"
                ]
            }
        ],
        "frontmatter_schema": {
            "required": [
                "title",
                "slug",
                "description",
                "category"
            ],
            "optional": [
                "date",
                "author",
                "tags",
                "image",
                "readingTime"
            ]
        },
        "word_count": {
            "min": 1000,
            "max": 2500
        },
        "language": "en"
    },
    "sources": {
        "type": "markdown",
        "path": "knowledge/"
    },
    "output": {
        "content_dir": "content/blog/",
        "knowledge_dir": "knowledge/",
        "queue_dir": "topics-queue/"
    },
    "pipeline": {
        "concurrency": 3,
        "ai_provider": "gemini-cli",
        "auto_validate": true,
        "auto_publish": false,
        "git_branch": "main"
    },
    "audit": {
        "error_patterns": [
            "I cannot",
            "Please provide",
            "As an AI"
        ],
        "min_headings": 4,
        "require_faq": true,
        "require_cta": true,
        "require_disclaimer": true
    },
    "memory": {
        "enabled": true,
        "memory_dir": "memory/",
        "auto_learn": true,
        "max_episodic_days": 90
    },
    "research": {
        "auto_research": true,
        "search_provider": "browser",
        "competitor_urls": [],
        "max_sources_per_topic": 10
    },
    "scoring": {
        "reward_praise": 10,
        "reward_engagement": 5,
        "reward_first_pass": 3,
        "penalty_edit": -5,
        "penalty_delete": -10,
        "penalty_audit_fail": -3
    },
    "extensions": {
        "openclaw": {
            "enabled": false
        },
        "hooks": {}
    }
}