{
    "niche": "personal-finance",
    "brand": {
        "name": "WealthPath Academy",
        "slogan": "Master Your Money, Build Your Future",
        "tone": "educational-empowering",
        "language": "en",
        "colors": {
            "primary": "#0A2540",
            "secondary": "#00D4AA",
            "accent": "#F6F9FC"
        }
    },
    "content": {
        "article_types": [
            {
                "id": "investing-guide",
                "title_template": "{topic_name}: Complete Investing Guide for Beginners & Beyond",
                "category": "investing",
                "seo_intent": "informational",
                "tags_base": [
                    "investing",
                    "portfolio",
                    "returns"
                ]
            },
            {
                "id": "savings-strategy",
                "title_template": "How to Save for {topic_name}: Proven Strategies That Work",
                "category": "savings",
                "seo_intent": "transactional",
                "tags_base": [
                    "savings",
                    "budgeting",
                    "goals"
                ]
            },
            {
                "id": "product-review",
                "title_template": "Best {topic_name} in 2025: Honest Review & Comparison",
                "category": "reviews",
                "seo_intent": "commercial",
                "tags_base": [
                    "review",
                    "comparison",
                    "best"
                ]
            },
            {
                "id": "tax-guide",
                "title_template": "{topic_name} Tax Guide: Deductions, Credits & Filing Tips",
                "category": "taxes",
                "seo_intent": "informational",
                "tags_base": [
                    "tax",
                    "deductions",
                    "filing"
                ]
            },
            {
                "id": "faq-article",
                "title_template": "{topic_name}: 10 Money Questions Answered by Financial Experts",
                "category": "faq",
                "seo_intent": "informational",
                "tags_base": [
                    "FAQ",
                    "money",
                    "advice"
                ]
            }
        ],
        "frontmatter_schema": {
            "required": [
                "title",
                "slug",
                "description",
                "category"
            ],
            "optional": [
                "date",
                "author",
                "tags",
                "image"
            ]
        },
        "word_count": {
            "min": 1200,
            "max": 3000
        },
        "language": "en",
        "disclaimer": "This content is for educational purposes only and does not constitute financial advice."
    },
    "sources": {
        "type": "markdown",
        "path": "knowledge/"
    },
    "output": {
        "content_dir": "content/blog/",
        "knowledge_dir": "knowledge/",
        "queue_dir": "topics-queue/"
    },
    "pipeline": {
        "concurrency": 3,
        "ai_provider": "gemini-cli",
        "auto_validate": true,
        "auto_publish": false,
        "git_branch": "main"
    },
    "audit": {
        "error_patterns": [
            "I cannot",
            "Please provide",
            "As an AI"
        ],
        "min_headings": 4,
        "require_faq": true,
        "require_cta": true,
        "require_disclaimer": true
    },
    "memory": {
        "enabled": true,
        "memory_dir": "memory/",
        "auto_learn": true,
        "max_episodic_days": 90
    },
    "research": {
        "auto_research": true,
        "search_provider": "browser",
        "competitor_urls": [],
        "max_sources_per_topic": 10
    },
    "scoring": {
        "reward_praise": 10,
        "reward_engagement": 5,
        "reward_first_pass": 3,
        "penalty_edit": -5,
        "penalty_delete": -10,
        "penalty_audit_fail": -3
    },
    "extensions": {
        "openclaw": {
            "enabled": false
        },
        "hooks": {}
    }
}