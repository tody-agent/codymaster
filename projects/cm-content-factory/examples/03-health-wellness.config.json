{
    "niche": "health-wellness",
    "brand": {
        "name": "VitalLife Hub",
        "slogan": "Evidence-Based Wellness for Modern Living",
        "tone": "warm-scientific",
        "language": "en",
        "colors": {
            "primary": "#2D6A4F",
            "secondary": "#B7E4C7",
            "accent": "#FEFAE0"
        }
    },
    "content": {
        "article_types": [
            {
                "id": "condition-guide",
                "title_template": "{topic_name}: Symptoms, Causes & Natural Remedies That Work",
                "category": "conditions",
                "seo_intent": "informational",
                "tags_base": [
                    "health",
                    "symptoms",
                    "remedies"
                ]
            },
            {
                "id": "nutrition-article",
                "title_template": "Best Foods for {topic_name}: Science-Backed Diet Guide",
                "category": "nutrition",
                "seo_intent": "informational",
                "tags_base": [
                    "nutrition",
                    "diet",
                    "superfoods"
                ]
            },
            {
                "id": "supplement-review",
                "title_template": "Top {topic_name} Supplements: Reviews, Dosage & Side Effects",
                "category": "supplements",
                "seo_intent": "commercial",
                "tags_base": [
                    "supplements",
                    "review",
                    "dosage"
                ]
            },
            {
                "id": "exercise-protocol",
                "title_template": "{topic_name} Exercise Protocol: Doctor-Approved Workout Plan",
                "category": "fitness",
                "seo_intent": "transactional",
                "tags_base": [
                    "exercise",
                    "workout",
                    "protocol"
                ]
            },
            {
                "id": "faq-article",
                "title_template": "{topic_name}: Your Health Questions Answered by Medical Experts",
                "category": "faq",
                "seo_intent": "informational",
                "tags_base": [
                    "FAQ",
                    "health",
                    "doctor"
                ]
            }
        ],
        "frontmatter_schema": {
            "required": [
                "title",
                "slug",
                "description",
                "category"
            ],
            "optional": [
                "date",
                "author",
                "tags",
                "image",
                "medicalReviewer"
            ]
        },
        "word_count": {
            "min": 1000,
            "max": 2500
        },
        "language": "en",
        "disclaimer": "This content is for informational purposes only. Always consult a healthcare professional before making health decisions."
    },
    "sources": {
        "type": "markdown",
        "path": "knowledge/"
    },
    "output": {
        "content_dir": "content/blog/",
        "knowledge_dir": "knowledge/",
        "queue_dir": "topics-queue/"
    },
    "pipeline": {
        "concurrency": 3,
        "ai_provider": "gemini-cli",
        "auto_validate": true,
        "auto_publish": false,
        "git_branch": "main"
    },
    "audit": {
        "error_patterns": [
            "I cannot",
            "Please provide",
            "As an AI"
        ],
        "min_headings": 5,
        "require_faq": true,
        "require_cta": true,
        "require_disclaimer": true
    },
    "memory": {
        "enabled": true,
        "memory_dir": "memory/",
        "auto_learn": true,
        "max_episodic_days": 90
    },
    "research": {
        "auto_research": true,
        "search_provider": "browser",
        "competitor_urls": [],
        "max_sources_per_topic": 10
    },
    "scoring": {
        "reward_praise": 10,
        "reward_engagement": 5,
        "reward_first_pass": 3,
        "penalty_edit": -5,
        "penalty_delete": -10,
        "penalty_audit_fail": -3
    },
    "extensions": {
        "openclaw": {
            "enabled": false
        },
        "hooks": {}
    }
}