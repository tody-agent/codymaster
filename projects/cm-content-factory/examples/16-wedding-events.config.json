{
    "niche": "wedding-events",
    "brand": {
        "name": "WedPlan Pro",
        "slogan": "Plan Your Perfect Day with Confidence",
        "tone": "romantic-organized",
        "language": "en",
        "colors": {
            "primary": "#B45309",
            "secondary": "#FBBF24",
            "accent": "#FFFBEB"
        }
    },
    "content": {
        "article_types": [
            {
                "id": "planning-guide",
                "title_template": "{topic_name} Wedding Planning: Timeline, Budget & Expert Tips",
                "category": "planning",
                "seo_intent": "informational",
                "tags_base": [
                    "wedding planning",
                    "timeline",
                    "checklist"
                ]
            },
            {
                "id": "vendor-guide",
                "title_template": "Best {topic_name} Wedding Vendors: Reviews, Pricing & Booking Tips",
                "category": "vendors",
                "seo_intent": "commercial",
                "tags_base": [
                    "vendors",
                    "reviews",
                    "booking"
                ]
            },
            {
                "id": "cost-breakdown",
                "title_template": "{topic_name} Wedding Cost: Real Budget Breakdown (2025)",
                "category": "costs",
                "seo_intent": "transactional",
                "tags_base": [
                    "cost",
                    "budget",
                    "pricing"
                ]
            },
            {
                "id": "inspiration",
                "title_template": "{topic_name} Wedding Ideas: Trends, Themes & Color Palettes",
                "category": "inspiration",
                "seo_intent": "informational",
                "tags_base": [
                    "ideas",
                    "trends",
                    "themes"
                ]
            },
            {
                "id": "diy-guide",
                "title_template": "DIY {topic_name} for Your Wedding: Save Money Without Compromising",
                "category": "diy",
                "seo_intent": "informational",
                "tags_base": [
                    "DIY",
                    "budget",
                    "creative"
                ]
            }
        ],
        "frontmatter_schema": {
            "required": [
                "title",
                "slug",
                "description",
                "category"
            ],
            "optional": [
                "date",
                "author",
                "tags",
                "image",
                "season",
                "budgetRange"
            ]
        },
        "word_count": {
            "min": 1000,
            "max": 2500
        },
        "language": "en"
    },
    "sources": {
        "type": "manual",
        "path": "knowledge/"
    },
    "output": {
        "content_dir": "content/blog/",
        "knowledge_dir": "knowledge/",
        "queue_dir": "topics-queue/"
    },
    "pipeline": {
        "concurrency": 3,
        "ai_provider": "gemini-cli",
        "auto_validate": true,
        "auto_publish": false,
        "git_branch": "main"
    },
    "audit": {
        "error_patterns": [
            "I cannot",
            "Please provide",
            "As an AI"
        ],
        "min_headings": 4,
        "require_faq": true,
        "require_cta": true,
        "require_disclaimer": false
    },
    "memory": {
        "enabled": true,
        "memory_dir": "memory/",
        "auto_learn": true,
        "max_episodic_days": 90
    },
    "research": {
        "auto_research": true,
        "search_provider": "browser",
        "competitor_urls": [],
        "max_sources_per_topic": 10
    },
    "scoring": {
        "reward_praise": 10,
        "reward_engagement": 5,
        "reward_first_pass": 3,
        "penalty_edit": -5,
        "penalty_delete": -10,
        "penalty_audit_fail": -3
    },
    "extensions": {
        "openclaw": {
            "enabled": false
        },
        "hooks": {}
    }
}