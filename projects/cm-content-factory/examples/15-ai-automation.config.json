{
    "niche": "ai-automation",
    "brand": {
        "name": "AIToolKit Pro",
        "slogan": "Automate Everything, Build Faster",
        "tone": "cutting-edge-practical",
        "language": "en",
        "colors": {
            "primary": "#0F172A",
            "secondary": "#38BDF8",
            "accent": "#F1F5F9"
        }
    },
    "content": {
        "article_types": [
            {
                "id": "tool-review",
                "title_template": "{topic_name} Review: Features, Pricing & Real-World Results",
                "category": "reviews",
                "seo_intent": "commercial",
                "tags_base": [
                    "AI tool",
                    "review",
                    "automation"
                ]
            },
            {
                "id": "how-to-guide",
                "title_template": "How to Use {topic_name} for Business: Automation Playbook",
                "category": "guides",
                "seo_intent": "informational",
                "tags_base": [
                    "how to",
                    "automation",
                    "business"
                ]
            },
            {
                "id": "comparison",
                "title_template": "{topic_name}: Top AI Tools Compared (Features, Pricing, Speed)",
                "category": "comparisons",
                "seo_intent": "commercial",
                "tags_base": [
                    "comparison",
                    "AI tools",
                    "best"
                ]
            },
            {
                "id": "workflow-article",
                "title_template": "Automate {topic_name} with AI: Save 10+ Hours/Week",
                "category": "workflows",
                "seo_intent": "transactional",
                "tags_base": [
                    "workflow",
                    "productivity",
                    "automation"
                ]
            },
            {
                "id": "prompt-guide",
                "title_template": "{topic_name} Prompts: 50 Ready-to-Use Templates for Better Output",
                "category": "prompts",
                "seo_intent": "informational",
                "tags_base": [
                    "prompts",
                    "templates",
                    "AI"
                ]
            }
        ],
        "frontmatter_schema": {
            "required": [
                "title",
                "slug",
                "description",
                "category"
            ],
            "optional": [
                "date",
                "author",
                "tags",
                "image",
                "difficulty",
                "timeSaved"
            ]
        },
        "word_count": {
            "min": 1200,
            "max": 3000
        },
        "language": "en"
    },
    "sources": {
        "type": "manual",
        "path": "knowledge/"
    },
    "output": {
        "content_dir": "content/blog/",
        "knowledge_dir": "knowledge/",
        "queue_dir": "topics-queue/"
    },
    "pipeline": {
        "concurrency": 3,
        "ai_provider": "gemini-cli",
        "auto_validate": true,
        "auto_publish": false,
        "git_branch": "main"
    },
    "audit": {
        "error_patterns": [
            "I cannot",
            "Please provide",
            "As an AI"
        ],
        "min_headings": 4,
        "require_faq": true,
        "require_cta": true,
        "require_disclaimer": false
    },
    "memory": {
        "enabled": true,
        "memory_dir": "memory/",
        "auto_learn": true,
        "max_episodic_days": 90
    },
    "research": {
        "auto_research": true,
        "search_provider": "browser",
        "competitor_urls": [],
        "max_sources_per_topic": 10
    },
    "scoring": {
        "reward_praise": 10,
        "reward_engagement": 5,
        "reward_first_pass": 3,
        "penalty_edit": -5,
        "penalty_delete": -10,
        "penalty_audit_fail": -3
    },
    "extensions": {
        "openclaw": {
            "enabled": false
        },
        "hooks": {}
    }
}