{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Content Factory Configuration",
    "description": "Configuration schema for the AI Content Factory pipeline",
    "type": "object",
    "required": [
        "niche",
        "brand",
        "content",
        "sources",
        "output"
    ],
    "properties": {
        "niche": {
            "type": "string",
            "description": "Domain identifier (e.g., medspa-tcm, fitness, tech-blog)"
        },
        "brand": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string"
                },
                "slogan": {
                    "type": "string"
                },
                "tone": {
                    "type": "string",
                    "description": "Writing tone (e.g., professional-warm, casual, academic)"
                },
                "language": {
                    "type": "string",
                    "default": "vi"
                },
                "colors": {
                    "type": "object",
                    "properties": {
                        "primary": {
                            "type": "string"
                        },
                        "secondary": {
                            "type": "string"
                        },
                        "accent": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "content": {
            "type": "object",
            "required": [
                "article_types",
                "frontmatter_schema"
            ],
            "properties": {
                "article_types": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "id",
                            "title_template",
                            "category"
                        ],
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "title_template": {
                                "type": "string"
                            },
                            "category": {
                                "type": "string"
                            },
                            "seo_intent": {
                                "type": "string",
                                "enum": [
                                    "informational",
                                    "commercial",
                                    "transactional",
                                    "educational"
                                ]
                            },
                            "tags_base": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "template_file": {
                                "type": "string"
                            }
                        }
                    }
                },
                "frontmatter_schema": {
                    "type": "object",
                    "description": "Required and optional frontmatter fields",
                    "properties": {
                        "required": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "optional": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                },
                "word_count": {
                    "type": "object",
                    "properties": {
                        "min": {
                            "type": "integer",
                            "default": 500
                        },
                        "max": {
                            "type": "integer",
                            "default": 1200
                        }
                    }
                },
                "language": {
                    "type": "string",
                    "description": "Language code for content output (e.g., 'en', 'vi', 'zh'). Must be set explicitly."
                },
                "disclaimer": {
                    "type": "string",
                    "description": "Required disclaimer text appended to content"
                }
            }
        },
        "sources": {
            "type": "object",
            "required": [
                "type",
                "path"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "docx",
                        "pdf",
                        "url",
                        "markdown",
                        "manual"
                    ],
                    "description": "Source material format"
                },
                "path": {
                    "type": "string"
                },
                "group_map": {
                    "type": "object",
                    "description": "Keyword → group code mapping for source files",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "group_names": {
                    "type": "object",
                    "description": "Group code → display name mapping",
                    "additionalProperties": {
                        "type": "string"
                    }
                }
            }
        },
        "output": {
            "type": "object",
            "required": [
                "content_dir"
            ],
            "properties": {
                "content_dir": {
                    "type": "string",
                    "default": "content/blog/"
                },
                "knowledge_dir": {
                    "type": "string",
                    "default": "knowledge-base/"
                },
                "queue_dir": {
                    "type": "string",
                    "default": "topics-queue/"
                },
                "templates_dir": {
                    "type": "string"
                },
                "reports_dir": {
                    "type": "string",
                    "default": "."
                }
            }
        },
        "pipeline": {
            "type": "object",
            "properties": {
                "concurrency": {
                    "type": "integer",
                    "default": 3,
                    "minimum": 1,
                    "maximum": 10
                },
                "ai_provider": {
                    "type": "string",
                    "enum": [
                        "gemini-cli",
                        "openai",
                        "anthropic",
                        "custom"
                    ],
                    "default": "gemini-cli"
                },
                "ai_model": {
                    "type": "string"
                },
                "auto_validate": {
                    "type": "boolean",
                    "default": true
                },
                "auto_publish": {
                    "type": "boolean",
                    "default": false
                },
                "git_branch": {
                    "type": "string",
                    "default": "main"
                },
                "build_command": {
                    "type": "string"
                }
            }
        },
        "seo": {
            "type": "object",
            "properties": {
                "title_max_length": {
                    "type": "integer",
                    "default": 60
                },
                "description_max_length": {
                    "type": "integer",
                    "default": 160
                },
                "slug_max_length": {
                    "type": "integer",
                    "default": 75
                },
                "keyword_density": {
                    "type": "object",
                    "properties": {
                        "min": {
                            "type": "number",
                            "default": 0.5
                        },
                        "max": {
                            "type": "number",
                            "default": 1.5
                        }
                    }
                }
            }
        },
        "audit": {
            "type": "object",
            "properties": {
                "error_patterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Regex patterns to detect AI garbage/errors in content"
                },
                "min_headings": {
                    "type": "integer",
                    "default": 3
                },
                "require_faq": {
                    "type": "boolean",
                    "default": true
                },
                "require_cta": {
                    "type": "boolean",
                    "default": true
                },
                "require_disclaimer": {
                    "type": "boolean",
                    "default": false
                }
            }
        },
        "extensions": {
            "type": "object",
            "properties": {
                "openclaw": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean",
                            "default": false
                        },
                        "endpoint": {
                            "type": "string"
                        },
                        "api_key_env": {
                            "type": "string",
                            "default": "OPENCLAW_API_KEY"
                        },
                        "agents": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "OpenClaw agent IDs to invoke"
                        }
                    }
                },
                "hooks": {
                    "type": "object",
                    "properties": {
                        "pre_extract": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "post_extract": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "pre_plan": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "post_plan": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "pre_write": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "post_write": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "pre_audit": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "post_audit": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "pre_publish": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "post_publish": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    }
}