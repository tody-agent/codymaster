{
    "niche": "pet-care",
    "brand": {
        "name": "PawGuide Pro",
        "slogan": "Happy Pets, Happy Life",
        "tone": "loving-knowledgeable",
        "language": "en",
        "colors": {
            "primary": "#7C3AED",
            "secondary": "#F59E0B",
            "accent": "#FAF5FF"
        }
    },
    "content": {
        "article_types": [
            {
                "id": "breed-guide",
                "title_template": "{topic_name}: Temperament, Care Needs, Cost & Is It Right for You?",
                "category": "breeds",
                "seo_intent": "informational",
                "tags_base": [
                    "breed guide",
                    "pet care",
                    "choosing"
                ]
            },
            {
                "id": "health-article",
                "title_template": "{topic_name} in Pets: Symptoms, Treatment & Vet-Approved Advice",
                "category": "health",
                "seo_intent": "informational",
                "tags_base": [
                    "pet health",
                    "symptoms",
                    "vet advice"
                ]
            },
            {
                "id": "product-review",
                "title_template": "Best {topic_name} for Pets 2025: Vet-Recommended Reviews",
                "category": "reviews",
                "seo_intent": "commercial",
                "tags_base": [
                    "best products",
                    "review",
                    "vet recommended"
                ]
            },
            {
                "id": "training-guide",
                "title_template": "How to Train Your Pet for {topic_name}: Positive Method Guide",
                "category": "training",
                "seo_intent": "informational",
                "tags_base": [
                    "training",
                    "behavior",
                    "tips"
                ]
            },
            {
                "id": "nutrition-article",
                "title_template": "{topic_name} Diet: Vet-Approved Feeding Guide & Best Foods",
                "category": "nutrition",
                "seo_intent": "commercial",
                "tags_base": [
                    "pet food",
                    "nutrition",
                    "diet"
                ]
            }
        ],
        "frontmatter_schema": {
            "required": [
                "title",
                "slug",
                "description",
                "category"
            ],
            "optional": [
                "date",
                "author",
                "tags",
                "image",
                "petType"
            ]
        },
        "word_count": {
            "min": 1000,
            "max": 2500
        },
        "language": "en",
        "disclaimer": "Always consult your veterinarian for pet health decisions."
    },
    "sources": {
        "type": "manual",
        "path": "knowledge/"
    },
    "output": {
        "content_dir": "content/blog/",
        "knowledge_dir": "knowledge/",
        "queue_dir": "topics-queue/"
    },
    "pipeline": {
        "concurrency": 3,
        "ai_provider": "gemini-cli",
        "auto_validate": true,
        "auto_publish": false,
        "git_branch": "main"
    },
    "audit": {
        "error_patterns": [
            "I cannot",
            "Please provide",
            "As an AI"
        ],
        "min_headings": 4,
        "require_faq": true,
        "require_cta": true,
        "require_disclaimer": true
    },
    "memory": {
        "enabled": true,
        "memory_dir": "memory/",
        "auto_learn": true,
        "max_episodic_days": 90
    },
    "research": {
        "auto_research": true,
        "search_provider": "browser",
        "competitor_urls": [],
        "max_sources_per_topic": 10
    },
    "scoring": {
        "reward_praise": 10,
        "reward_engagement": 5,
        "reward_first_pass": 3,
        "penalty_edit": -5,
        "penalty_delete": -10,
        "penalty_audit_fail": -3
    },
    "extensions": {
        "openclaw": {
            "enabled": false
        },
        "hooks": {}
    }
}