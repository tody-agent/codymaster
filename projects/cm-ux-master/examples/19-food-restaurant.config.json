{
    "niche": "food-restaurant",
    "brand": {
        "name": "TasteGuide",
        "slogan": "Discover, Cook, Savor",
        "tone": "passionate-detailed",
        "language": "en",
        "colors": {
            "primary": "#92400E",
            "secondary": "#F59E0B",
            "accent": "#FFFBEB"
        }
    },
    "content": {
        "article_types": [
            {
                "id": "recipe-article",
                "title_template": "{topic_name} Recipe: Easy Step-by-Step Guide (Ready in 30 Min)",
                "category": "recipes",
                "seo_intent": "informational",
                "tags_base": [
                    "recipe",
                    "cooking",
                    "easy"
                ]
            },
            {
                "id": "restaurant-review",
                "title_template": "Best {topic_name} Restaurants 2025: Reviews, Menu & Reservations",
                "category": "restaurants",
                "seo_intent": "commercial",
                "tags_base": [
                    "restaurant",
                    "review",
                    "dining"
                ]
            },
            {
                "id": "kitchen-gear",
                "title_template": "Best {topic_name} Kitchen Equipment: Professional Reviews & Picks",
                "category": "equipment",
                "seo_intent": "commercial",
                "tags_base": [
                    "kitchen",
                    "equipment",
                    "review"
                ]
            },
            {
                "id": "cuisine-guide",
                "title_template": "{topic_name} Cuisine Guide: History, Techniques & Must-Try Dishes",
                "category": "cuisines",
                "seo_intent": "informational",
                "tags_base": [
                    "cuisine",
                    "culture",
                    "dishes"
                ]
            },
            {
                "id": "meal-prep",
                "title_template": "{topic_name} Meal Prep: Weekly Plan, Shopping List & Storage Tips",
                "category": "meal-prep",
                "seo_intent": "transactional",
                "tags_base": [
                    "meal prep",
                    "planning",
                    "healthy"
                ]
            }
        ],
        "frontmatter_schema": {
            "required": [
                "title",
                "slug",
                "description",
                "category"
            ],
            "optional": [
                "date",
                "author",
                "tags",
                "image",
                "prepTime",
                "servings",
                "calories"
            ]
        },
        "word_count": {
            "min": 800,
            "max": 2000
        },
        "language": "en"
    },
    "sources": {
        "type": "manual",
        "path": "knowledge/"
    },
    "output": {
        "content_dir": "content/blog/",
        "knowledge_dir": "knowledge/",
        "queue_dir": "topics-queue/"
    },
    "pipeline": {
        "concurrency": 3,
        "ai_provider": "gemini-cli",
        "auto_validate": true,
        "auto_publish": false,
        "git_branch": "main"
    },
    "audit": {
        "error_patterns": [
            "I cannot",
            "Please provide",
            "As an AI"
        ],
        "min_headings": 3,
        "require_faq": true,
        "require_cta": true,
        "require_disclaimer": false
    },
    "memory": {
        "enabled": true,
        "memory_dir": "memory/",
        "auto_learn": true,
        "max_episodic_days": 90
    },
    "research": {
        "auto_research": true,
        "search_provider": "browser",
        "competitor_urls": [],
        "max_sources_per_topic": 10
    },
    "scoring": {
        "reward_praise": 10,
        "reward_engagement": 5,
        "reward_first_pass": 3,
        "penalty_edit": -5,
        "penalty_delete": -10,
        "penalty_audit_fail": -3
    },
    "extensions": {
        "openclaw": {
            "enabled": false
        },
        "hooks": {}
    }
}