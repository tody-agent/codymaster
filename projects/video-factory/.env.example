# ============================================================
# CM Video Factory — Environment Configuration
# ============================================================
# Copy to .env and fill values. NEVER commit .env to git.
# ============================================================

# --- AI / LLM ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- TTS Engines ---
# ElevenLabs (English TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=george
ELEVENLABS_MODEL=eleven_multilingual_v2

# VieNeu-TTS (Vietnamese — local, no key needed)
VIENEU_TTS_ENABLED=true
VIENEU_TTS_MODEL=0.5b

# OpenAI TTS (fallback)
OPENAI_TTS_VOICE=nova
OPENAI_TTS_MODEL=tts-1-hd

# --- NotebookLM ---
# Auth handled by `nlm login` — no key needed here
NLM_MAX_SOURCES_PER_NOTEBOOK=7
NLM_AUDIO_OVERVIEW_ENABLED=true

# --- Publishing ---
# Browser sessions stored in ./sessions/ (gitignored)
PUBLISH_YOUTUBE_ENABLED=true
PUBLISH_TIKTOK_ENABLED=true
PUBLISH_REELS_ENABLED=false

# --- Rate Limits (Policy Compliance) ---
TIKTOK_MAX_DAILY_UPLOADS=3
TIKTOK_COOLDOWN_HOURS=4
YOUTUBE_MAX_DAILY_UPLOADS=2
YOUTUBE_COOLDOWN_HOURS=6

# --- Render ---
DEFAULT_FORMAT=tiktok
RENDER_CONCURRENCY=2
RENDER_LOG_LEVEL=info
